# Configuración del API (copiar a apps/api/.env en desarrollo). NUNCA commitear .env real.
ENVIRONMENT=development

# Infra
DATABASE_URL=postgresql+psycopg://slopguard:slopguard@localhost:5432/slopguard
REDIS_URL=redis://localhost:6379/0

# Sesión y cifrado en reposo (AEAD) — generar valores fuertes en cada entorno
SESSION_SECRET=change-me-with-a-strong-random-value
ENCRYPTION_KEY=  # clave AEAD base64 de 32 bytes (H5-T06)

# Front
CORS_ORIGINS=["http://localhost:3000"]

# GitHub OAuth + App + Webhooks (Olas 1/4/5)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
